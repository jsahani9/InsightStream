# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/insightstream
DATABASE_NEON_URL=postgresql+asyncpg://neondb_owner:your-neon-password@your-neon-host/neondb?sslmode=require&channel_binding=require

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
BEDROCK_CLAUDE_MODEL_ID=global.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_LLAMA_MODEL_ID=us.meta.llama3-3-70b-instruct-v1:0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_PLANNER_MODEL=your-openai-planner-model
OPENAI_VERIFIER_MODEL=your-openai-verifier-model
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Web Search ────────────────────────────────────────────────────────────────
SERPER_API_KEY=your-serper-api-key

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
